{
  "hosting": [
    {
      "target": "catalogue",
      "public": ".",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**", "client/**"]
    },
    {
      "target": "client",
      "public": "client",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "cleanUrls": true,
      "404": "404.html",
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    }
  ]
}
